<header class="site-header">
  <div class="container nav">
    <a class="logo" href="<%= baseUrl === '..' ? '../index.html' : '#' %>" aria-label="CollectIn home">
      <img src="<%= baseUrl %>/assets/icon-32.png" alt="CollectIn logo" class="logo-icon">
      <span class="logo-text">CollectIn<%= title.includes('Help') ? ' Help' : '' %></span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <% navigation.forEach(function(nav) { %>
        <a href="<%= nav.href %>">
          <%= nav.text %>
        </a>
        <% }); %>
    </nav>
    <a class="button primary" href="#" id="cta-top">Add to Chrome</a>
  </div>
</header>