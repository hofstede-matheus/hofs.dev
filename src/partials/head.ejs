<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= title %>
  </title>
  <meta name="description" content="<%= description %>" />

  <!-- Preconnect to external domains for faster loading -->
  <link rel="preconnect" href="https://chromewebstore.google.com">

  <!-- Non-blocking CSS loading for better performance -->
  <link rel="preload"
    href="<%= baseUrl %>/assets/<%= typeof pageType !== 'undefined' && pageType === 'privacy' ? 'privacy.css' : 'index.css' %>"
    as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link rel="stylesheet"
      href="<%= baseUrl %>/assets/<%= typeof pageType !== 'undefined' && pageType === 'privacy' ? 'privacy.css' : 'index.css' %>">
  </noscript>
  <% if (typeof additionalCSS !=='undefined' ) { %>
    <%- additionalCSS %>
      <% } %>
        <link rel="icon" href="<%= baseUrl %>/assets/icon-16.png" sizes="16x16" type="image/png">
        <link rel="icon" href="<%= baseUrl %>/assets/icon-32.png" sizes="32x32" type="image/png">
        <link rel="icon" href="<%= baseUrl %>/assets/icon-48.png" sizes="48x48" type="image/png">
        <link rel="icon" href="<%= baseUrl %>/assets/icon-128.png" sizes="128x128" type="image/png">
</head>