<!doctype html>
<html lang="en">

<%- include('../partials/head') %>

  <body>
    <%- include('../partials/header') %>

      <main>
        <section class="hero">
          <div class="container hero-grid">
            <div class="hero-copy">
              <h1>Help - CollectIn</h1>
              <p class="lead">Learn how to use CollectIn to organize your LinkedIn saved posts.</p>
              <p class="lead">Click on the extension <span><img src="../assets/icon-16.png" alt="icon"></span> in Chrome
                to open this page anytime.</p>
            </div>
          </div>
        </section>

        <section id="features-help" class="features-help">
          <div class="container">
            <h2>Features</h2>
            <div class="feature-help-grid">
              <div class="feature-help">
                <h3>Set a collection</h3>
                <video width="100%" height="auto" autoplay muted playsinline loop class="hero-video">
                  <source src="../assets/demo-save-post.webm" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <p>After saving a post, you'll be prompted to add it to a collection.</p>
              </div>
              <div class="feature-help">
                <h3>Filter posts by collection</h3>
                <video width="100%" height="auto" autoplay muted playsinline loop class="hero-video">
                  <source src="../assets/demo-change-filter.webm" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <p>Use collection filters on the saved posts and articles page to quickly find what you need.</p>
              </div>
              <div class="feature-help">
                <h3>Create a new collection</h3>
                <video width="100%" height="auto" autoplay muted playsinline loop class="hero-video">
                  <source src="../assets/demo-create-collection.webm" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <p>Create new collections instantly by clicking the "+" pill in LinkedIn's filter list.</p>
              </div>
              <div class="feature-help">
                <h3>Rename an existing collection</h3>
                <video width="100%" height="auto" autoplay muted playsinline loop class="hero-video">
                  <source src="../assets/demo-rename-collection.webm" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <p>Rename an existing collection by long-pressing on the collection name in the filter list.</p>
              </div>
              <div class="feature-help">
                <h3>Remove a collection</h3>
                <video width="100%" height="auto" autoplay muted playsinline loop class="hero-video">
                  <source src="../assets/demo-delete-collection.webm" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <p>Long-press a collection name and click the trash icon. Posts will move to "Uncategorized" collection.
                </p>
              </div>
              <div class="feature-help">
                <h3>Update a collection from a saved post</h3>
                <video width="100%" height="auto" autoplay muted playsinline loop class="hero-video">
                  <source src="../assets/demo-update-post-collection.webm" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <p>Click on the collection name of a saved post to change its collection.</p>
              </div>
            </div>
          </div>
        </section>

        <section class="cta">
          <div class="container cta-box">
            <h2>Get organized in minutes</h2>
            <p>Install the extension and bring order to your LinkedIn saves.</p>
            <a class="button primary large" href="#">Add to Chrome</a>
          </div>
        </section>

        <section id="faq" class="faq">
          <div class="container">
            <h2>FAQ</h2>
            <div class="faq-grid">
              <article>
                <h3>Does this change my LinkedIn account?</h3>
                <p>No. It visually augments the Saved page in your browser. Nothing is posted to your profile.</p>
              </article>
              <article>
                <h3>Is it free?</h3>
                <p>Yes. The core features are free.</p>
              </article>
            </div>
          </div>
        </section>
      </main>

      <%- include('../partials/footer') %>
  </body>

</html>